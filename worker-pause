#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-common.sh"

PROJECT_SELECTOR="${1:?usage: worker-pause <project-name|.|path>}"
worker_set_project_paths_from_selector "$PROJECT_SELECTOR"
worker_require_project_dir

worker_stop_active_pid

if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux kill-session -t "$SESSION"
  echo "Paused tmux session: $SESSION"
else
  echo "No tmux session found: $SESSION"
fi

echo "Worker paused."
echo "Resume with: worker-continue \"$BASE\""
