#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-common.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-runner-prompts.sh"

usage() {
  echo "usage: worker-redirect <project-name|.|path> <redirect instructions...>" >&2
  exit 2
}

[ $# -lt 2 ] && usage

PROJECT_SELECTOR="$1"
shift
REDIRECT="$*"

worker_set_project_paths_from_selector "$PROJECT_SELECTOR"
worker_require_project_dir

mkdir -p "$LOG_DIR"
cd "$BASE"

worker_load_roles

worker_stop_active_pid
tmux kill-session -t "$SESSION" 2>/dev/null || true

cat > "$REDIRECT_BRIEF_FILE" <<EOF
OPERATOR REDIRECT:
$REDIRECT

FILES TO CONSIDER:
- PLAN.md
- TASK.md
- REVIEW.md
- .worker/status.md
- .worker/stitch.json
EOF

PROMPT="$(make_redirect_prompt)"

worker_stamp_artifacts
BEFORE_FP="$(worker_fingerprint_files "$PLAN_FILE" "$TASK_FILE" "$REVIEW_FILE" "$STATUS_FILE")"
: > "$TEMP_FILE"
echo "=== redirect controller=$CONTROLLER | $(worker_ts) ===" | tee -a "$LOG_FILE"

if [ "$CONTROLLER" = "codex" ]; then
  codex exec --json "$PROMPT" 2>&1 | tee -a "$LOG_FILE" | tee "$TEMP_FILE"
  EXIT_CODE=${PIPESTATUS[0]}
else
  claude -p \
    --model sonnet \
    --permission-mode bypassPermissions \
    --max-turns 10 \
    --output-format stream-json \
    --verbose \
    --include-partial-messages \
    --append-system-prompt "$(cat "$SYSTEM_PROMPT_FILE")" \
    "$PROMPT" 2>&1 | tee -a "$LOG_FILE" | tee "$TEMP_FILE"
  EXIT_CODE=${PIPESTATUS[0]}
fi

if [ "$EXIT_CODE" -ne 0 ]; then
  if worker_provider_auth_failed; then
    echo "Controller provider '$CONTROLLER' is not authenticated." >&2
  else
    echo "Controller redirect step failed." >&2
  fi
  exit 1
fi

worker_stamp_artifacts
AFTER_FP="$(worker_fingerprint_files "$PLAN_FILE" "$TASK_FILE" "$REVIEW_FILE" "$STATUS_FILE")"

if worker_provider_noop || [ "$BEFORE_FP" = "$AFTER_FP" ]; then
  echo "Controller did not make meaningful artifact changes." >&2
  exit 1
fi

echo "Redirect applied. Session stopped. Review artifacts, then run:"
echo "worker-continue \"$BASE\""
