#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-common.sh"

PROJECT_SELECTOR="${1:?usage: worker-status <project-name|.|path>}"
worker_set_project_paths_from_selector "$PROJECT_SELECTOR"
worker_require_project_dir

echo "=== TASK.md ==="
cat "$TASK_FILE" 2>/dev/null || echo "missing"
echo

echo "=== REVIEW.md ==="
cat "$REVIEW_FILE" 2>/dev/null || echo "missing"
echo

echo "=== status.md ==="
cat "$STATUS_FILE" 2>/dev/null || echo "missing"
