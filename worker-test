#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-common.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-test.sh"

[ $# -lt 2 ] && worker_test_usage

PROJECT_SELECTOR="$1"
shift
PROVIDER="$1"
shift

worker_test_require_provider "$PROVIDER"
worker_test_require_authkey
worker_set_project_paths_from_selector "$PROJECT_SELECTOR"
worker_require_project_dir
worker_init_project_dirs

NOTES="$*"

echo "Generating test stack for: $BASE"
worker_test_generate_stack "$PROVIDER" "$NOTES"

BLOCKED_REASON="$(worker_test_blocked_reason)"
if [ -n "$BLOCKED_REASON" ]; then
  worker_test_notify_slack_blocked "$BLOCKED_REASON"
  echo "Blocked: $BLOCKED_REASON" >&2
  exit 1
fi

worker_test_remove_previous_sidecars
TAILNET_DOMAIN="$(worker_test_tailnet_domain)"
worker_test_runtime_write "$TAILNET_DOMAIN"
worker_test_write_preview_compose
if ! worker_test_compose_up; then
  worker_test_notify_slack_failure "docker compose up failed"
  exit 1
fi
if ! worker_test_wait_for_sidecars; then
  worker_test_notify_slack_failure "tailscale sidecars did not become ready"
  exit 1
fi
if [ "$(worker_test_refresh_runtime_urls_from_sidecars)" = "changed" ]; then
  worker_test_write_preview_compose
  if ! worker_test_compose_up; then
    worker_test_notify_slack_failure "docker compose up failed after refreshing preview URLs"
    exit 1
  fi
fi
if ! worker_test_apply_routes; then
  worker_test_notify_slack_failure "failed to enable Funnel on preview sidecars"
  exit 1
fi
worker_test_print_summary
worker_test_notify_slack_status
