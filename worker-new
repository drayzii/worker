#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-common.sh"

usage() {
  echo "usage: worker-new <project-name> [--controller codex|claude] [--executor codex|claude] [--escalation codex|claude] <project prompt...>" >&2
  exit 2
}

[ $# -lt 2 ] && usage

NAME="$1"
shift

worker_set_project_paths_from_name "$NAME"
worker_default_roles

while [ $# -gt 0 ]; do
  case "$1" in
    --controller) CONTROLLER="${2:-}"; shift 2 ;;
    --executor) EXECUTOR="${2:-}"; shift 2 ;;
    --escalation) ESCALATION="${2:-}"; shift 2 ;;
    --) shift; break ;;
    -*) echo "Unknown option: $1" >&2; usage ;;
    *) break ;;
  esac
done

PROMPT="$*"
[ -z "$PROMPT" ] && usage

mkdir -p "$BASE/.worker/tools" "$LOG_DIR"
cd "$BASE"

if [ ! -d .git ]; then
  git init
fi

read_template_file WORKER.md > "$WORKER_RULES_FILE"

cat > "$BASE/.worker/tools/local-llm" <<'EOF'
#!/usr/bin/env bash
exec "__LOCAL_LLM_BIN__" "$@"
EOF
python3 - "$BASE/.worker/tools/local-llm" "$LOCAL_LLM_BIN" <<'PY'
import pathlib, sys
path = pathlib.Path(sys.argv[1])
target = sys.argv[2]
path.write_text(path.read_text().replace("__LOCAL_LLM_BIN__", target))
PY
chmod +x "$BASE/.worker/tools/local-llm"

worker_write_roles

read_template_file status.md > "$STATUS_FILE"

: > "$PLAN_FILE"
: > "$TASK_FILE"
: > "$REVIEW_FILE"
: > "$LOG_FILE"
: > "$TEMP_FILE"
: > "$CONTROLLER_BRIEF_FILE"
: > "$EXECUTOR_BRIEF_FILE"
: > "$REVIEW_BRIEF_FILE"
: > "$ESCALATION_BRIEF_FILE"
rm -f "$STATE_FILE" "$ACTIVE_FILE" "$EXTRA_FILE"

STAMP_TS="$(worker_utc_now)"
worker_stamp_file_end "$PLAN_FILE" "$STAMP_TS"
worker_stamp_file_end "$TASK_FILE" "$STAMP_TS"
worker_stamp_file_end "$REVIEW_FILE" "$STAMP_TS"
worker_stamp_file_end "$STATUS_FILE" "$STAMP_TS"

printf '%s\n' "$PROMPT" > "$INITIAL_PROMPT_FILE"

CMD="cd '$BASE' && '$RUNNER_BIN' '$BASE' new; echo; echo '[worker shell ready]'; exec zsh"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux kill-session -t "$SESSION"
fi

tmux new-session -d -s "$SESSION" "$CMD"

echo "started"
echo "project: $BASE"
echo "session: $SESSION"
echo "roles: controller=$CONTROLLER executor=$EXECUTOR escalation=$ESCALATION"
echo "log: $LOG_FILE"
