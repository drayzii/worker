#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: worker-new <project-name> [--controller codex|claude] [--executor codex|claude] [--escalation codex|claude] <project prompt...>" >&2
  exit 2
}

stamp_file_end() {
  local file="$1"
  local ts="$2"
  python3 - "$file" "$ts" <<'PY'
import pathlib, re, sys
p = pathlib.Path(sys.argv[1])
ts = sys.argv[2]
text = p.read_text() if p.exists() else ""
text = re.sub(r'\n*UPDATED_AT:\s*[^\n]*\s*\Z', '', text, flags=re.S)
text = text.rstrip('\n')
if text:
    text += '\n\n'
text += f'UPDATED_AT: {ts}\n'
p.write_text(text)
PY
}

[ $# -lt 2 ] && usage

NAME="$1"
shift

CONTROLLER="codex"
EXECUTOR="codex"
ESCALATION="claude"

while [ $# -gt 0 ]; do
  case "$1" in
    --controller) CONTROLLER="${2:-}"; shift 2 ;;
    --executor) EXECUTOR="${2:-}"; shift 2 ;;
    --escalation) ESCALATION="${2:-}"; shift 2 ;;
    --) shift; break ;;
    -*) echo "Unknown option: $1" >&2; usage ;;
    *) break ;;
  esac
done

PROMPT="$*"
[ -z "$PROMPT" ] && usage

BASE="$HOME/Projects/$NAME"
SESSION="worker-$NAME"
SYSTEM_PROMPT_FILE="$HOME/.config/ai-worker/system-prompt.txt"

mkdir -p "$BASE/.worker/tools" "$BASE/.worker/logs" "$HOME/.config/ai-worker"
cd "$BASE"

if [ ! -d .git ]; then
  git init
fi

cat > "$SYSTEM_PROMPT_FILE" <<'SPROMPT'
You are part of an autonomous software-engineering workflow.

Global rules:
- Work autonomously from the project prompt and project files.
- Do not ask for confirmation.
- Either continue, revise, replan, escalate, or mark complete.
- Use local models only for tiny boilerplate or optional manual summaries, not for orchestration.
- If the project has a UI, use Playwright for critical paths.
- Use 21st.dev as design inspiration when frontend design matters.
- Never deploy unless explicitly requested in the original project prompt.
SPROMPT

cat > "$BASE/CLAUDE.md" <<'EOF2'
# Project worker rules

- Controller owns PLAN.md, TASK.md, REVIEW.md, and commit decisions.
- Executor only implements the current TASK.md.
- Escalation only handles the current blocker.
- Do not ask for confirmation.
- Do not use local models for planning, review, milestone order, debugging strategy, or test-loop control.
- .worker/status.md is runtime state only.
EOF2

cat > "$BASE/.worker/tools/local-llm" <<'EOF2'
#!/usr/bin/env bash
exec "$HOME/bin/local-llm" "$@"
EOF2
chmod +x "$BASE/.worker/tools/local-llm"

cat > "$BASE/.worker/roles.env" <<EOF2
CONTROLLER=$CONTROLLER
EXECUTOR=$EXECUTOR
ESCALATION=$ESCALATION
EOF2

cat > "$BASE/.worker/status.md" <<'EOF2'
PHASE: Starting
CURRENT_MILESTONE:
LAST_ACTION: initialized worker
NEXT_ACTION: controller should create PLAN.md and TASK.md
CONTROLLER_DECISION: PLAN
ESCALATE_TO_PROVIDER: NO
BLOCKER:
STATUS: INCOMPLETE
EOF2

: > "$BASE/PLAN.md"
: > "$BASE/TASK.md"
: > "$BASE/REVIEW.md"
: > "$BASE/.worker/logs/run.log"
: > "$BASE/.worker/logs/current-run.ndjson"
: > "$BASE/.worker/controller-brief.md"
: > "$BASE/.worker/executor-brief.md"
: > "$BASE/.worker/review-brief.md"
: > "$BASE/.worker/escalation-brief.md"
rm -f "$BASE/.worker/runtime.env" "$BASE/.worker/ACTIVE.pid" "$BASE/.worker/continue-extra.txt"

STAMP_TS="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
stamp_file_end "$BASE/PLAN.md" "$STAMP_TS"
stamp_file_end "$BASE/TASK.md" "$STAMP_TS"
stamp_file_end "$BASE/REVIEW.md" "$STAMP_TS"
stamp_file_end "$BASE/.worker/status.md" "$STAMP_TS"

printf '%s\n' "$PROMPT" > "$BASE/.worker/initial-prompt.txt"

CMD="cd '$BASE' && '$HOME/bin/worker-runner' '$BASE' new; echo; echo '[worker shell ready]'; exec zsh"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux kill-session -t "$SESSION"
fi

tmux new-session -d -s "$SESSION" "$CMD"

echo "started"
echo "project: $BASE"
echo "session: $SESSION"
echo "roles: controller=$CONTROLLER executor=$EXECUTOR escalation=$ESCALATION"
echo "log: $BASE/.worker/logs/run.log"
