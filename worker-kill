#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-common.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-test.sh"

PROJECT_SELECTOR="${1:?usage: worker-kill <project-name|.|path> [--purge-volumes]}"
PURGE_VOLUMES="${2:-}"

worker_set_project_paths_from_selector "$PROJECT_SELECTOR"

echo "Before:"
tmux ls 2>/dev/null || echo "No tmux sessions"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux kill-session -t "$SESSION"
  echo "Killed tmux session: $SESSION"
else
  echo "No tmux session found: $SESSION"
fi

if [ -d "$BASE" ]; then
  cd "$BASE"
  worker_test_remove_previous_sidecars
  rm -f "$TEST_RUNTIME_FILE" "$TEST_ENV_FILE" "$TEST_PREVIEW_COMPOSE_FILE"
  rm -rf "$TEST_TAILSCALE_DIR"
  if [ -f docker-compose.yml ] || [ -f docker-compose.yaml ] || [ -f compose.yml ] || [ -f compose.yaml ]; then
    echo "Stopping Docker Compose services..."
    if [ "$PURGE_VOLUMES" = "--purge-volumes" ]; then
      docker compose down -v || docker-compose down -v
    else
      docker compose down || docker-compose down
    fi
  else
    echo "No compose file found, skipping Docker shutdown."
  fi
else
  echo "Project directory not found: $BASE"
fi

echo
echo "After:"
tmux ls 2>/dev/null || echo "No tmux sessions"
