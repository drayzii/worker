#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-common.sh"

usage() {
  echo "usage: worker-continue <project-name> [--controller codex|claude] [--executor codex|claude] [--escalation codex|claude] [extra instructions...]" >&2
  exit 2
}

[ $# -lt 1 ] && usage

NAME="$1"
shift || true

worker_set_project_paths_from_name "$NAME"
worker_require_project_dir

NEW_CONTROLLER=""
NEW_EXECUTOR=""
NEW_ESCALATION=""

while [ $# -gt 0 ]; do
  case "$1" in
    --controller) NEW_CONTROLLER="${2:-}"; shift 2 ;;
    --executor) NEW_EXECUTOR="${2:-}"; shift 2 ;;
    --escalation) NEW_ESCALATION="${2:-}"; shift 2 ;;
    --) shift; break ;;
    -*) echo "Unknown option: $1" >&2; usage ;;
    *) break ;;
  esac
done

EXTRA="$*"

mkdir -p "$LOG_DIR"
cd "$BASE"

worker_load_roles
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-runner-prompts.sh"

[ -n "$NEW_CONTROLLER" ] && CONTROLLER="$NEW_CONTROLLER"
[ -n "$NEW_EXECUTOR" ] && EXECUTOR="$NEW_EXECUTOR"
[ -n "$NEW_ESCALATION" ] && ESCALATION="$NEW_ESCALATION"

worker_write_roles

{
  read_template_file continue-extra.txt
  if [ -n "$EXTRA" ]; then
    printf '%s\n' "$EXTRA"
  fi
} > "$EXTRA_FILE"

rm -f "$ACTIVE_FILE"

python3 - "$STATUS_FILE" "$PLAN_FILE" "$TASK_FILE" "$REVIEW_FILE" <<'PY'
import pathlib, re, sys

status_file = pathlib.Path(sys.argv[1])
plan_file = pathlib.Path(sys.argv[2])
task_file = pathlib.Path(sys.argv[3])
review_file = pathlib.Path(sys.argv[4])

def nonempty(p: pathlib.Path) -> bool:
    return p.exists() and p.stat().st_size > 0

status = status_file.read_text() if status_file.exists() else ""
have_any_artifacts = nonempty(plan_file) or nonempty(task_file) or nonempty(review_file)

def set_field(text: str, key: str, value: str) -> str:
    pat = rf'^{re.escape(key)}:.*$'
    rep = f'{key}: {value}'
    if re.search(pat, text, flags=re.M):
        return re.sub(pat, rep, text, flags=re.M)
    return text.rstrip() + ('\n' if text and not text.endswith('\n') else '') + rep + '\n'

m = re.search(r'^CONTROLLER_DECISION:\s*(.*)$', status, flags=re.M)
decision = m.group(1).strip().upper() if m else ""

if have_any_artifacts and decision in {"PLAN", "REPLAN"}:
    status = set_field(status, "CONTROLLER_DECISION", "REVISE")
    status_file.write_text(status)
PY

START_STAGE="$(python3 - "$STATUS_FILE" "$PLAN_FILE" "$TASK_FILE" "$REVIEW_FILE" <<'PY'
import pathlib, re, sys

status_file = pathlib.Path(sys.argv[1])
plan_file = pathlib.Path(sys.argv[2])
task_file = pathlib.Path(sys.argv[3])
review_file = pathlib.Path(sys.argv[4])

def nonempty(p: pathlib.Path) -> bool:
    return p.exists() and p.stat().st_size > 0

status = status_file.read_text() if status_file.exists() else ""

def field(name: str) -> str:
    m = re.search(rf'^{re.escape(name)}:\s*(.*)$', status, flags=re.M)
    return m.group(1).strip().upper() if m else ""

have_plan = nonempty(plan_file)
have_task = nonempty(task_file)
have_review = nonempty(review_file)

escalate = field("ROUTE_TO_ESCALATION")
status_value = field("STATUS")

if escalate in {"YES", "TRUE", "1"}:
    print("escalation")
elif have_task and status_value != "COMPLETE":
    print("executor")
elif have_plan and have_review:
    print("controller_review")
else:
    print("controller_plan")
PY
)"

if [ -f "$STATE_FILE" ]; then
  python3 - "$STATE_FILE" "$START_STAGE" <<'PY'
import pathlib, re, sys
p = pathlib.Path(sys.argv[1])
start_stage = sys.argv[2]
text = p.read_text()

def sub_or_add(text, key, value):
    pat = rf'^{key}=.*$'
    rep = f'{key}={value}'
    if re.search(pat, text, flags=re.M):
        return re.sub(pat, rep, text, flags=re.M)
    return text.rstrip() + '\n' + rep + '\n'

text = sub_or_add(text, 'ITERATION', '0')
text = sub_or_add(text, 'STAGE', start_stage)
text = sub_or_add(text, 'EXECUTOR_FAILURES', '0')
text = sub_or_add(text, 'ESCALATION_FAILURES', '0')
text = sub_or_add(text, 'CONTROLLER_FAILURES', '0')
p.write_text(text)
PY
else
  cat > "$STATE_FILE" <<EOF
ITERATION=0
STAGE=$START_STAGE
EXECUTOR_FAILURES=0
ESCALATION_FAILURES=0
CONTROLLER_FAILURES=0
EOF
fi

echo "Resuming at stage: $START_STAGE"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux send-keys -t "$SESSION" C-c
  tmux send-keys -t "$SESSION" "cd \"$BASE\"" C-m
  tmux send-keys -t "$SESSION" "\"$RUNNER_BIN\" \"$BASE\" continue" C-m
else
  tmux new-session -d -s "$SESSION" "cd \"$BASE\" && \"$RUNNER_BIN\" \"$BASE\" continue; echo; echo '[worker shell ready]'; exec zsh"
fi
