#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-common.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/worker-test.sh"

[ $# -lt 1 ] && worker_test_status_usage

PROJECT_SELECTOR="$1"

worker_set_project_paths_from_selector "$PROJECT_SELECTOR"
worker_require_project_dir

if [ ! -f "$TEST_STACK_FILE" ]; then
  echo "No test stack found: $TEST_STACK_FILE" >&2
  exit 1
fi

BLOCKED_REASON="$(worker_test_blocked_reason)"
if [ -n "$BLOCKED_REASON" ]; then
  echo "Blocked: $BLOCKED_REASON"
  exit 0
fi

if [ ! -f "$TEST_RUNTIME_FILE" ]; then
  echo "No active test runtime found: $TEST_RUNTIME_FILE" >&2
  exit 1
fi

worker_test_print_summary
echo
worker_test_status_verify
